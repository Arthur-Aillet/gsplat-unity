#define GROUP_SIZE 1024

#pragma kernel PreCompute

uint _Count;
RWStructuredBuffer<uint> _OrderBuffer;

[numthreads(GROUP_SIZE,1,1)]
void PreCompute(uint3 id : SV_DispatchThreadID)
{
    uint idx = id.x;
    if (idx >= _Count)
        return;

    if (idx % 2 == 0) {
        idx = _OrderBuffer[idx];
    }
}
